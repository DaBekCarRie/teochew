{
  "name": "teochew",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli start --android",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "web": "node node_modules/expo/bin/cli start --web",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo/node",
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.ts",
      "<rootDir>/src/__tests__/**/*.test.tsx"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/node_modules/@react-native-async-storage/async-storage/jest/async-storage-mock.js"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@expo/cli": "54.0.23",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "react-test-renderer": "^19.2.5",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
